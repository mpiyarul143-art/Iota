# ── Iota AI chat (powers the /ai command) ──
# AI_PROVIDER: "openai" (any OpenAI-compatible Chat Completions endpoint) or "gemini"
# Leave AI_API_KEY empty to disable the /ai command (it replies with a notice).
AI_PROVIDER=openai
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=1024
AI_SYSTEM_PROMPT=You are Iota, a helpful, friendly AI assistant inside the Iota Music Bot.
